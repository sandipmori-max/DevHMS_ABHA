require_relative '../node_modules/react-native/scripts/react_native_pods'

platform :ios, '16.0'  # 👈 MLKit requires iOS 13.0+

prepare_react_native_project!

use_frameworks! :linkage => :static
use_modular_headers!

# 📌 Import the react-native-permissions setup script
def node_require(script)
  require Pod::Executable.execute_command('node', ['-p',
    "require.resolve('#{script}', {paths: [process.argv[1]]})",
    __dir__
  ]).strip
end

# 🧩 Import the setup scripts
node_require('react-native/scripts/react_native_pods.rb')
node_require('react-native-permissions/scripts/setup.rb')

# ✨ IMPORTANT: list only the permissions your app needs
setup_permissions([
   'Camera',
   'Microphone',
   'Notifications',
   'LocationAlways',
   'LocationWhenInUse',
   'PhotoLibrary',
   'PhotoLibraryAddOnly',
   'MediaLibrary'
])

target 'DevERP' do
  config = use_native_modules!

   use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => true,
    :fabric_enabled => false,
   )

  # 👇 Add this line for MLKit integration
  pod 'GoogleMLKit/TextRecognitionChinese', '8.0.0'

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath]
    )
  end
end
